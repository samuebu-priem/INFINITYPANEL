# Backend env example (production-ready baseline)

NODE_ENV=production
PORT=3001

# Single origin in production (avoid "*").
# Example: https://your-domain.com
CORS_ORIGIN=

# Postgres (required)
# Example:
# postgresql://user:pass@localhost:5432/dbname?schema=public
DATABASE_URL=

# Auth (required)
JWT_SECRET=
JWT_EXPIRES_IN=7d

# WebSocket
WS_PATH=/ws

# Discord (optional)
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=

# Payments
PAYMENT_PROVIDER=MERCADO_PAGO

MERCADO_PAGO_PUBLIC_KEY=
MERCADO_PAGO_ACCESS_TOKEN=
MERCADO_PAGO_WEBHOOK_SECRET=

# Public HTTPS URL that Mercado Pago will call
MERCADO_PAGO_WEBHOOK_URL=https://your-domain.com/api/payments/webhook/mercadopago

# Frontend redirects (optional but recommended for checkout UX)
FRONTEND_CHECKOUT_SUCCESS_URL=https://your-domain.com/checkout/success
FRONTEND_CHECKOUT_FAILURE_URL=https://your-domain.com/checkout/failure
FRONTEND_CHECKOUT_PENDING_URL=https://your-domain.com/checkout/pending
